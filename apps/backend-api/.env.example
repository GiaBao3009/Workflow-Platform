# ==================== SMTP EMAIL CONFIGURATION ====================
# Để gửi email thật, cấu hình SMTP của bạn tại đây

# Gmail SMTP (Recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Workflow Platform

# Outlook/Hotmail SMTP
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false

# SendGrid SMTP
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# Other settings
FRONTEND_URL=http://localhost:5174

# ==================== HƯỚNG DẪN CẤU HÌNH GMAIL ====================
# 1. Bật 2-Step Verification: https://myaccount.google.com/security
# 2. Tạo App Password: https://myaccount.google.com/apppasswords
# 3. Chọn "Mail" và "Other (Custom name)"
# 4. Copy password 16 ký tự và paste vào SMTP_PASS
# 5. Restart backend sau khi cập nhật

# Example:
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=abcd efgh ijkl mnop  (16-character app password)
