# ==================== MONGODB ====================
# Get this from MongoDB Atlas: Dashboard → Connect → Drivers
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://workflow_user:YOUR_PASSWORD@workflow-db.xxxx.mongodb.net/workflow-db?retryWrites=true&w=majority

# ==================== TEMPORAL ====================
# Address of Temporal Server
# Development: localhost:7233
# Docker: temporal:7233
TEMPORAL_ADDRESS=localhost:7233

# ==================== BACKEND API ====================
# Backend API port
BACKEND_PORT=3001

# Backend API URL (for webhook generation)
API_URL=http://localhost:3001

# ==================== FRONTEND ====================
# Frontend port
FRONTEND_PORT=3000

# ==================== ENVIRONMENT ====================
# development, staging, production
NODE_ENV=development

# ==================== LOGGING ====================
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ==================== RATE LIMITING ====================
# Max workflow runs per hour per workflow
MAX_RUNS_PER_HOUR=100

# ==================== SECURITY ====================
# JWT Secret for authentication (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_secret_here_change_in_production

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ==================== MONGODB POOL ====================
# Connection pool settings
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=5

# ==================== TEMPORAL SETTINGS ====================
# Task queue name
TEMPORAL_TASK_QUEUE=default

# Workflow timeout (seconds)
TEMPORAL_WORKFLOW_TIMEOUT=3600

# Activity timeout (seconds)
TEMPORAL_ACTIVITY_TIMEOUT=600

# ==================== EMAIL (for future use) ====================
# SMTP settings for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ==================== WEBHOOKS ====================
# Webhook signing secret (for security)
WEBHOOK_SECRET=your_webhook_secret_here_change_in_production

# Webhook retry attempts
WEBHOOK_RETRY_ATTEMPTS=3

# ==================== METRICS ====================
# Enable metrics collection
ENABLE_METRICS=true

# Metrics backend (prometheus, datadog, etc)
METRICS_BACKEND=prometheus
